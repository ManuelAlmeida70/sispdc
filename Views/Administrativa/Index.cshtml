@model List<SisPDC.Models.Entities.ConsultaModel>

@{
    Layout = "_LayoutAdmin";
}



@section Styles {
    <link href="~/css/pessoalClinico.css" rel="stylesheet" />
}

<!-- Main Content -->
<div class="main-content">


    <!-- Content Area -->
    <div class="content-area">
        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="stat-card blue">
                <div class="stat-info">
                    <h3>1,248</h3>
                    <p>Total Pacientes</p>
                </div>
                <div class="stat-icon">
                    <i class="bi bi-people-fill"></i>
                </div>
            </div>

            <div class="stat-card green">
                <div class="stat-info">
                    <h3>156</h3>
                    <p>Consultas Hoje</p>
                </div>
                <div class="stat-icon">
                    <i class="bi bi-calendar-check-fill"></i>
                </div>
            </div>

            <div class="stat-card orange">
                <div class="stat-info">
                    <h3>89</h3>
                    <p>Médicos Ativos</p>
                </div>
                <div class="stat-icon">
                    <i class="bi bi-person-badge-fill"></i>
                </div>
            </div>

            <div class="stat-card red">
                <div class="stat-info">
                    <h3>23</h3>
                    <p>Emergências</p>
                </div>
                <div class="stat-icon">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
            </div>
        </div>
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show m-4" role="alert">
                <i class="bi bi-check-circle me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <!-- Charts Grid -->
        <div class="chart-grid">
            <div class="chart-card">
                <h4>Consultas Mensais</h4>
                <div class="chart-placeholder">
                    <div class="chart-bars">
                        <div class="bar" style="height: 60%;"></div>
                        <div class="bar" style="height: 85%;"></div>
                        <div class="bar" style="height: 45%;"></div>
                        <div class="bar" style="height: 70%;"></div>
                        <div class="bar" style="height: 55%;"></div>
                        <div class="bar" style="height: 90%;"></div>
                        <div class="bar" style="height: 65%;"></div>
                        <div class="bar" style="height: 75%;"></div>
                        <div class="bar" style="height: 50%;"></div>
                        <div class="bar" style="height: 80%;"></div>
                        <div class="bar" style="height: 70%;"></div>
                        <div class="bar" style="height: 95%;"></div>
                    </div>
                </div>
            </div>

            <div class="chart-card">
                <h4>Departamentos</h4>
                <div style="padding: 20px 0;">
                    <div style="margin-bottom: 20px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                            <span style="font-size: 14px; color: #666;">Cardiologia</span>
                            <span style="font-weight: 600;">78%</span>
                        </div>
                        <div style="background: #e0e0e0; height: 8px; border-radius: 10px;">
                            <div style="background: #1e88e5; width: 78%; height: 100%; border-radius: 10px;"></div>
                        </div>
                    </div>
                    <div style="margin-bottom: 20px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                            <span style="font-size: 14px; color: #666;">Pediatria</span>
                            <span style="font-weight: 600;">65%</span>
                        </div>
                        <div style="background: #e0e0e0; height: 8px; border-radius: 10px;">
                            <div style="background: #43a047; width: 65%; height: 100%; border-radius: 10px;"></div>
                        </div>
                    </div>
                    <div style="margin-bottom: 20px;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                            <span style="font-size: 14px; color: #666;">Ortopedia</span>
                            <span style="font-weight: 600;">52%</span>
                        </div>
                        <div style="background: #e0e0e0; height: 8px; border-radius: 10px;">
                            <div style="background: #fb8c00; width: 52%; height: 100%; border-radius: 10px;"></div>
                        </div>
                    </div>
                    <div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                            <span style="font-size: 14px; color: #666;">Neurologia</span>
                            <span style="font-weight: 600;">43%</span>
                        </div>
                        <div style="background: #e0e0e0; height: 8px; border-radius: 10px;">
                            <div style="background: #e53935; width: 43%; height: 100%; border-radius: 10px;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Appointments List -->
        <div class="appointments-list">
            
        </div>
</div>

@section Scripts {
        <script src="~/js/site.js"></script>
}
