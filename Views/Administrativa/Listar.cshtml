@model List<SisPDC.Models.Entities.PessoaAdministrativaModel>


@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Listar Administrativos";
}

@section Styles {
    <link href="~/css/pessoalClinico.css" rel="stylesheet" />
}


<div class="content-wrapper">

    <a asp-action="GerarRelatorioPDF" asp-controller="Administrativo" class="btn btn-primary text-white" target="_blank">
        <i class="bi bi-file-pdf me-2"></i> Gerar Relatório PDF
    </a>
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="data-table-card">
        <div class="table-header">
            <h4><i class="bi bi-people-fill me-2"></i> Lista de Pessoal Administrativo</h4>
            <a asp-action="Criar" asp-controller="Administrativa" class="btn btn-primary mb-3">
                <i class="bi bi-person-plus-fill me-2"></i> Adicionar Pessoal Administrativo
            </a>
        </div>
        <div class="table-responsive p-2">
            <table id="especialidade" class="data-table">
                <thead>
                    <tr>
                        <th style="width: 5%;">ID</th>
                        <th style="width: 25%;">Nome</th>
                        <th style="width: 15%;">Cargo</th>
                        
                        <th style="width: 15%;">Telefone</th>
                        <th style="width: 10%;">Ativo</th>
                        <th style="width: 10%;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any() && Model != null)
                    {
                        foreach(var administrativo in Model)
                        {
                            <tr>
                                <td>@administrativo.IdPessoaAdmin</td>
                                <td>@administrativo.Nome</td>
                                <td>@administrativo.Cargo</td>
                                <td>@administrativo.Telefone</td>
                                @* <td>@{(@administrativo.Ativo == true) ? "Ativo" : "Desativado"}</td> *@
                                <td>@{ string estado = (@administrativo.Ativo == true) ? "Ativo" : "Desativado";}@estado</td>
                                <td>
                                    <div class="action-buttons">
                                        <a asp-action="Editar" asp-controller="Administrativo"
                                           asp-route-id="@administrativo.IdPessoaAdmin" class="btn-action btn-edit">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        <a asp-action="Eliminar"
                                           asp-controller="Administrativo"
                                           asp-route-id="@administrativo.IdPessoaAdmin"
                                           class="btn-action btn-delete">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/site.js"></script>
}