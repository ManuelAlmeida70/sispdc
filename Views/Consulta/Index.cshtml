@model List<SisPDC.Models.Entities.ConsultaModel>


@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Listar Administrativos";
}

@section Styles {
    <link href="~/css/pessoalClinico.css" rel="stylesheet" />
}


<div class="content-wrapper">

    <a asp-action="GerarRelatorioPDF" asp-controller="Administrativo" class="btn btn-primary text-white" target="_blank">
        <i class="bi bi-file-pdf me-2"></i> Gerar Relatório PDF
    </a>
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="data-table-card">
        <div class="table-header">
            <h4><i class="bi bi-people-fill me-2"></i> Listagem de Consultas Agendadas</h4>
        </div>
        <div class="table-responsive p-2">
            <table id="especialidade" class="data-table">
                <thead>
                    <tr>
                        <th style="width: 5%;">ID Consulta</th>
                        <th style="width: 15%;">ID Utente</th>
                        <th style="width: 15%;">ID Pessoa Clínica</th>
                        <th style="width: 15%;">Data</th>
                        <th style="width: 10%;">Hora</th>
                        <th style="width: 25%;">Descrição</th>
                        <th style="width: 10%;">Estado</th>
                        <th style="width: 10%;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any() && Model != null)
                {
                    foreach (var consulta in Model)
                    {
                        <tr>
                            <td>@consulta.IdConsulta.ToString("#2")</td>
                            <td>@consulta.IdUtente</td>                         
                            <td>@consulta.IdPessoaClinica</td>
                                <td>@consulta.DataConsulta.ToString("dd/MM/yyyy")</td>
                            <td>@consulta.HoraConsulta</td>
                            <td>@consulta.Descricao</td>
                            <td>@consulta.Estado</td>
                            <td>
                                <div class="action-buttons">
                                    <a asp-action="Editar" asp-controller="Consulta"
                                        asp-route-id="@consulta.IdConsulta" class="btn-action btn-edit">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <a asp-action="Eliminar"
                                        asp-controller="Consulta"
                                        asp-route-id="@consulta.IdConsulta"
                                        class="btn-action btn-delete">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </div>
                            </td>
                            </tr>
                        }
                }            
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/site.js"></script>
}