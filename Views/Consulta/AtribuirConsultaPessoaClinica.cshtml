@model SisPDC.Models.Entities.ConsultaModel
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Atribuir Médico à Consulta";
}
@section Styles {
    <link href="~/css/pessoalClinico.css" rel="stylesheet" />
}

<div class="content-wrapper">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="data-table-card">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="bi bi-person-plus-fill me-2"></i> Atribuir Médico à Consulta
                </h5>
            </div>
            <div class="card-body">

                {{!-- Informações da Consulta --}}
                <h6 class="text-muted mb-3">
                    <i class="bi bi-calendar2-check me-1"></i> Informações da Consulta
                </h6>
                <div class="row mb-3">
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">Nº Consulta</label>
                        <input type="text" class="form-control" value="#@Model.IdConsulta" disabled />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Data</label>
                        <input type="text" class="form-control" value="@Model.DataConsulta.ToString("dd/MM/yyyy")" disabled />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">Hora</label>
                        <input type="text" class="form-control" value="@Model.HoraConsulta.ToString(@"hh\:mm")" disabled />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Estado</label>
                        <input type="text" class="form-control 
                            @(Model.Estado == "Pendente" ? "text-warning" : 
                              Model.Estado == "Marcado" ? "text-success" : 
                              Model.Estado == "Cancelada" ? "text-danger" : "")"
                               value="@Model.EstadoFormatado" disabled />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-12">
                        <label class="form-label fw-semibold">Descrição</label>
                        <textarea class="form-control" rows="2" disabled>@(Model.Descricao ?? "—")</textarea>
                    </div>
                </div>

                <hr />

                {{!-- Informações do Utente --}}
                <h6 class="text-muted mb-3">
                    <i class="bi bi-person me-1"></i> Informações do Utente
                </h6>
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Nº Utente</label>
                        <input type="text" class="form-control" value="@Model.IdUtente" disabled />
                    </div>
                    <div class="col-md-8">
                        <label class="form-label fw-semibold">Nome</label>
                        <input type="text" class="form-control" value="@(Model.Utente?.IdUtente ?? "—")" disabled />
                    </div>
                </div>

                <hr />

                {{!-- Atribuir Médico --}}
                <h6 class="text-muted mb-3">
                    <i class="bi bi-person-badge me-1"></i> Atribuir Médico
                </h6>
                <form asp-action="AtribuirConsultaPessoaClinica" asp-controller="Consulta" method="post">
                    <input type="hidden" name="idConsulta" value="@Model.IdConsulta" />

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Selecionar Médico</label>
                            <select name="idPessoaClinica" class="form-select" required>
                                <option value="">-- Selecione um médico --</option>
                                @if (ViewBag.Medicos != null)
                                {
                                    foreach (var medico in ViewBag.Medicos)
                                    {
                                        if (Model.IdPessoaClinica == medico.IdPessoaClinica)
                                        {
                                            <option value="@medico.IdPessoaClinica" selected>@medico.Nome</option>
                                        }
                                        else
                                        {
                                            <option value="@medico.IdPessoaClinica">@medico.Nome</option>
                                        }
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-2"></i>Atribuir
                        </button>
                        <a asp-action="Index" asp-controller="Consulta" class="btn btn-secondary">
                            <i class="bi bi-x-circle me-2"></i>Cancelar
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/site.js"></script>
}