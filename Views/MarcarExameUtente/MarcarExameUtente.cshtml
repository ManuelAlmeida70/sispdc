@model SisPDC.DTOs.CriarExameDTO

@{
    Layout = "_LayoutUtente";
    ViewData["Title"] = "Marcar Exame";

    var NumeroUtente = User.FindFirst("NumeroUtente")?.Value;
}

<!-- Main Content -->
<div class="container pb-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "HomeUtente")">Início</a></li>
            <li class="breadcrumb-item active" aria-current="page">Marcar Exame</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex align-items-center">
                <i class="bi bi-clipboard2-pulse text-primary fs-1 me-3"></i>
                <div>
                    <h2 class="mb-1">Marcar Novo Exame</h2>
                    <p class="text-muted mb-0">Agende um exame médico de forma simples e rápida</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Form Column -->
        <div class="col-lg-8">

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show m-4" role="alert">
                    <i class="bi bi-check-circle me-2"></i>
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show m-4" role="alert">
                    <i class="bi bi-exclamation-circle me-2"></i>
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }


            <div class="info-card">
                <form asp-action="MarcarExameUtente" asp-controller="HomeUtente" method="post" id="formMarcarExame">
                    <input asp-for="IdUtente" type="hidden" value="@NumeroUtente" />

                    <!-- Etapa 1: Tipo de Exame -->
                    <div class="mb-4">
                        <h5 class="section-title"><i class="bi bi-1-circle me-2"></i>Escolha o Tipo de Exame</h5>

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="TipoExame" class="form-label fw-bold">Tipo de Exame <span class="text-danger">*</span></label>
                                <select asp-for="TipoExame" class="form-select" id="tipoExame" required>
                                    <option value="">Selecione o tipo de exame</option>
                                    <optgroup label="Análises Clínicas">
                                        <option value="Hemograma Completo">Hemograma Completo</option>
                                        <option value="Glicemia">Glicemia</option>
                                        <option value="Colesterol Total">Colesterol Total</option>
                                        <option value="Ureia e Creatinina">Ureia e Creatinina</option>
                                        <option value="Transaminases">Transaminases (TGO/TGP)</option>
                                        <option value="Urina Tipo II">Urina Tipo II</option>
                                    </optgroup>
                                    <optgroup label="Imagiologia">
                                        <option value="Raio-X">Raio-X</option>
                                        <option value="Ecografia">Ecografia</option>
                                        <option value="Tomografia Computorizada">Tomografia Computorizada</option>
                                        <option value="Ressonância Magnética">Ressonância Magnética</option>
                                        <option value="Mamografia">Mamografia</option>
                                    </optgroup>
                                    <optgroup label="Cardiologia">
                                        <option value="Eletrocardiograma (ECG)">Eletrocardiograma (ECG)</option>
                                        <option value="Ecocardiograma">Ecocardiograma</option>
                                        <option value="Teste de Esforço">Teste de Esforço</option>
                                    </optgroup>
                                    <optgroup label="Outros">
                                        <option value="Endoscopia">Endoscopia</option>
                                        <option value="Colonoscopia">Colonoscopia</option>
                                        <option value="Espirometria">Espirometria</option>
                                    </optgroup>
                                </select>
                                <span asp-validation-for="TipoExame" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="Descricao" class="form-label fw-bold">Especificação do Exame</label>
                                <input asp-for="Descricao" type="text" class="form-control"
                                       placeholder="Ex: Raio-X de tórax, Hemograma de rotina, etc." maxlength="200" />
                                <span asp-validation-for="Descricao" class="text-danger"></span>
                                <small class="text-muted">Especifique a área ou tipo específico do exame</small>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <!-- Etapa 2: Dados da Requisição -->
                    <div class="mb-4">
                        <h5 class="section-title"><i class="bi bi-2-circle me-2"></i>Informações da Requisição</h5>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="IdConsulta" class="form-label fw-bold">Consulta de Origem (Opcional)</label>
                                <select asp-for="IdConsulta" class="form-select" id="consulta">
                                    <option value="">Sem consulta associada</option>
                                    <!-- Carregar consultas do utente via AJAX ou ViewBag -->
                                    @if(ViewBag.Consultas != null)
                                    {
                                        foreach(var consulta in ViewBag.Consultas)
                                        {
                                            <option value="@consulta.IdConsulta">@consulta.DataConsulta.ToString("dd/MM/yyyy") - @consulta.Descricao</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="IdConsulta" class="text-danger"></span>
                                <small class="text-muted">Vincule este exame a uma consulta anterior, se aplicável</small>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <!-- Etapa 3: Agendamento -->
                    <div class="mb-4">
                        <h5 class="section-title"><i class="bi bi-3-circle me-2"></i>Data do Exame</h5>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="DataPrevista" class="form-label fw-bold">Data Preferencial <span class="text-danger">*</span></label>
                                <input asp-for="DataPrevista" type="date" class="form-control" required
                                       min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="DataPrevista" class="text-danger"></span>
                                <small class="text-muted">A data pode ser ajustada conforme disponibilidade</small>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Período Preferencial</label>
                                <select class="form-select" id="periodoPreferencial">
                                    <option value="">Sem preferência</option>
                                    <option value="Manhã">Manhã (07:00 - 12:00)</option>
                                    <option value="Tarde">Tarde (14:00 - 18:00)</option>
                                </select>
                                <small class="text-muted">Indicação de horário preferido</small>
                            </div>
                        </div>

                        <!-- Alerta de Disponibilidade -->
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            <small>A confirmação da data será enviada por email/SMS após análise da disponibilidade.</small>
                        </div>
                    </div>

                    <hr class="my-4">

                    <!-- Etapa 4: Observações -->
                    <div class="mb-4">
                        <h5 class="section-title"><i class="bi bi-4-circle me-2"></i>Informações Adicionais</h5>

                        <div class="mb-3">
                            <label asp-for="Observacoes" class="form-label fw-bold">Observações</label>
                            <textarea asp-for="Observacoes" class="form-control" rows="4"
                                      placeholder="Inclua informações relevantes: jejum necessário, medicação em uso, alergias, condições especiais, etc."
                                      maxlength="500"></textarea>
                            <span asp-validation-for="Observacoes" class="text-danger"></span>
                            <small class="text-muted">0/500 caracteres</small>
                        </div>

                        <!-- Checklist de Preparação -->
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title"><i class="bi bi-clipboard-check me-2"></i>Preparação para o Exame</h6>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="jejum">
                                    <label class="form-check-label" for="jejum">
                                        <small>Necessita jejum (será confirmado após marcação)</small>
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="medicacao">
                                    <label class="form-check-label" for="medicacao">
                                        <small>Estou a tomar medicação (detalhe nas observações)</small>
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="alergias">
                                    <label class="form-check-label" for="alergias">
                                        <small>Tenho alergias conhecidas (especifique nas observações)</small>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Botões de Ação -->
                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                        <a href="@Url.Action("Index", "HomeUtente")" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Voltar
                        </a>
                        <div>
                            <button type="reset" class="btn btn-outline-danger me-2">
                                <i class="bi bi-x-circle me-2"></i>Limpar
                            </button>
                            <button type="submit" class="btn btn-primary btn-custom">
                                <i class="bi bi-check-circle me-2"></i>Confirmar Requisição
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Info Sidebar -->
        <div class="col-lg-4">
            <!-- Informações Importantes -->
            <div class="info-card">
                <h5 class="section-title small"><i class="bi bi-info-circle me-2"></i>Informações Importantes</h5>
                <div class="mb-3">
                    <div class="d-flex align-items-start mb-2">
                        <i class="bi bi-check-circle text-success me-2 mt-1"></i>
                        <small>Documentos necessários: BI/Passaporte e cartão do seguro</small>
                    </div>
                    <div class="d-flex align-items-start mb-2">
                        <i class="bi bi-check-circle text-success me-2 mt-1"></i>
                        <small>Traga pedido médico (se houver)</small>
                    </div>
                    <div class="d-flex align-items-start mb-2">
                        <i class="bi bi-check-circle text-success me-2 mt-1"></i>
                        <small>Resultados disponíveis em 24-72h (varia por tipo)</small>
                    </div>
                    <div class="d-flex align-items-start">
                        <i class="bi bi-check-circle text-success me-2 mt-1"></i>
                        <small>Confirmação será enviada por email/SMS</small>
                    </div>
                </div>
            </div>

            <!-- Preparação para Exames -->
            <div class="info-card">
                <h5 class="section-title small"><i class="bi bi-clipboard2-pulse me-2"></i>Preparação Comum</h5>
                <small class="text-muted">
                    <strong>Análises de sangue:</strong> Jejum de 8-12 horas<br>
                    <strong>Ecografia abdominal:</strong> Jejum de 6 horas<br>
                    <strong>Raio-X:</strong> Geralmente sem preparação<br>
                    <strong>Ressonância:</strong> Informar sobre implantes metálicos
                </small>
            </div>

            <!-- Política de Cancelamento -->
            <div class="info-card">
                <h5 class="section-title small"><i class="bi bi-exclamation-triangle me-2"></i>Política de Cancelamento</h5>
                <small class="text-muted">
                    Cancelamentos devem ser feitos com pelo menos 48 horas de antecedência.
                    Ausências não justificadas podem resultar em cobrança da taxa do exame.
                </small>
            </div>

            <!-- Contacto -->
            <div class="info-card">
                <h5 class="section-title small"><i class="bi bi-telephone me-2"></i>Precisa de Ajuda?</h5>
                <div class="mb-2">
                    <small class="text-muted">Telefone (Exames):</small>
                    <p class="mb-1 fw-bold">+244 923 456 790</p>
                </div>
                <div class="mb-2">
                    <small class="text-muted">Email:</small>
                    <p class="mb-0 fw-bold">exames@hospital.ao</p>
                </div>
                <small class="text-muted d-block mt-2">
                    Horário: Seg-Sex, 07:00-18:00 | Sáb, 08:00-13:00
                </small>
            </div>

            <!-- Exames Recentes -->
            <div class="info-card">
                <h5 class="section-title small"><i class="bi bi-clock-history me-2"></i>Últimos Exames</h5>
                <div class="list-group list-group-flush">
                    @if(ViewBag.ExamesRecentes != null && ViewBag.ExamesRecentes.Count > 0)
                    {
                        foreach(var exame in ViewBag.ExamesRecentes)
                        {
                            <div class="list-group-item px-0 py-2">
                                <small class="d-block fw-bold">@exame.TipoExame</small>
                                <small class="text-muted">@exame.DataRealizacao?.ToString("dd MMM, yyyy") - @exame.Estado</small>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="list-group-item px-0 py-2">
                            <small class="text-muted">Nenhum exame anterior registado</small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            // Contador de caracteres para observações
            $('textarea[name="Observacoes"]').on('input', function() {
                var length = $(this).val().length;
                var max = 500;
                $(this).next('.text-muted').text(`${length}/${max} caracteres`);
            });

            // Informações sobre tipo de exame
            $('#tipoExame').change(function() {
                var tipoExame = $(this).val();
                
                // Aqui você pode adicionar lógica para exibir informações específicas
                // sobre preparação, tempo de jejum, etc. baseado no tipo de exame
                
                if (tipoExame.includes('Hemograma') || tipoExame.includes('Glicemia')) {
                    $('#jejum').prop('checked', true);
                }
            });

            // Validação antes de submeter
            $('#formMarcarExame').submit(function(e) {
                var tipoExame = $('#tipoExame').val();
                var dataPrevista = $('input[name="DataPrevista"]').val();
                
                if (!tipoExame || !dataPrevista) {
                    e.preventDefault();
                    alert('Por favor, preencha todos os campos obrigatórios.');
                    return false;
                }
            });

            // Auto-preencher observações baseado nos checkboxes
            $('.form-check-input').change(function() {
                var observacoes = $('textarea[name="Observacoes"]').val();
                var novaObs = '';
                
                if ($('#jejum').is(':checked')) {
                    novaObs += 'Paciente disponível para jejum. ';
                }
                if ($('#medicacao').is(':checked')) {
                    novaObs += 'Medicação em uso - ver detalhes. ';
                }
                if ($('#alergias').is(':checked')) {
                    novaObs += 'Alergias conhecidas - ver detalhes. ';
                }
                
                if (novaObs && !observacoes.includes(novaObs)) {
                    $('textarea[name="Observacoes"]').val(observacoes + ' ' + novaObs);
                    $('textarea[name="Observacoes"]').trigger('input');
                }
            });
        });
    </script>
}